# NFS-root profile — used during early development; bypasses initramfs and mounts
# rootfs over NFSv3 from aibox/tc8 LXC. Adjust nfsroot host:path for your network.
KERNEL_CMDLINE="console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200 keep_bootcon panic=10 root=/dev/nfs nfsroot=192.168.10.230:/srv/nfs/tc8-debian,v3,tcp ip=:::::lan:dhcp rw rootwait"
